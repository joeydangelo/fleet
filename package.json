{
  "name": "get-fleet",
  "version": "0.1.0",
  "description": "Fleet — orchestrate multi-agent git worktree workflows",
  "license": "MIT",
  "author": "Joey D'Angelo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joeydangelo/fleet.git"
  },
  "homepage": "https://github.com/joeydangelo/fleet#readme",
  "bugs": {
    "url": "https://github.com/joeydangelo/fleet/issues"
  },
  "keywords": [
    "claude",
    "ai",
    "agents",
    "multi-agent",
    "worktree",
    "git",
    "orchestration",
    "cli"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "fleet": "./dist/bin.mjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  },
  "scripts": {
    "build": "tsdown && node scripts/copy-docs.mjs",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --fix && pnpm typecheck",
    "lint:check": "pnpm typecheck && eslint . --max-warnings 0",
    "format": "prettier --write --log-level warn .",
    "format:check": "prettier --check --log-level warn .",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "atomically": "^2.1.1",
    "commander": "^14.0.2",
    "fast-glob": "^3.3.3",
    "ink": "^6.8.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.4",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.19.7",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "lefthook": "^2.1.1",
    "prettier": "^3.8.1",
    "tsdown": "^0.20.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^2.1.9"
  }
}
